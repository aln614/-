{
  "name": "local-api-image-generator-webui",
  "version": "1.0.23",
  "description": "Local APIMart and Flow2API image generator with batch management",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:docker": "node src/docker-server.js",
    "docker:build": "docker build -t tenying-ai:1.0.23 .",
    "check": "node --check src/main.js && node --check src/renderer/static/app.js && node --check src/services/apiClient.js && node scripts/verify-image-models.js",
    "sync:unpacked": "npm run check && node scripts/sync-unpacked-asar.js --restart",
    "dist": "npm run check && electron-builder --win portable --config.win.signAndEditExecutable=false --config.forceCodeSigning=false",
    "dist:dir": "npm run check && electron-builder --win dir --config.win.signAndEditExecutable=false --config.forceCodeSigning=false"
  },
  "author": "Local",
  "license": "MIT",
  "devDependencies": {
    "electron": "35.7.5",
    "electron-builder": "25.1.8"
  },
  "build": {
    "appId": "com.local.api.image.generator.webui.v14_9_8",
    "productName": "TENYING_AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/rocket.ico",
      "target": [
        "portable"
      ],
      "artifactName": "TENYING_AI-${version}-win-${arch}.${ext}",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "artifactName": "TENYING_AI-${version}-win-${arch}.${ext}",
    "forceCodeSigning": false
  }
}
