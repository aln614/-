{
  "name": "local-api-image-generator-webui",
  "version": "1.0.1",
  "description": "Local APIMart and Flow2API image generator with batch management",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable --config.win.signAndEditExecutable=false --config.forceCodeSigning=false",
    "dist:dir": "electron-builder --win dir --config.win.signAndEditExecutable=false --config.forceCodeSigning=false"
  },
  "author": "Local",
  "license": "MIT",
  "devDependencies": {
    "electron": "35.7.5",
    "electron-builder": "25.1.8"
  },
  "build": {
    "appId": "com.local.api.image.generator.webui.v14_9_8",
    "productName": "TENYING_AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/rocket.ico",
      "target": [
        "portable"
      ],
      "artifactName": "TENYING_AI-${version}-win-${arch}.${ext}",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "artifactName": "TENYING_AI-${version}-win-${arch}.${ext}",
    "forceCodeSigning": false
  }
}
